<?php

/**
 * @file
 */

declare(strict_types=1);

/**
 * @file
 * Hook implementations for the LEAP Starter - Admin module.
 *
 * This module provides core administrative enhancements, including bulk
 * moderation actions, routing overrides to improve the content management
 * experience, and environment indicators for the administration toolbar.
 */

use Drupal\Core\Routing\RouteMatchInterface;

/**
 * Implements hook_help().
 *
 * Provides documentation and usage examples for the Administrative Enhancements
 * module, including instructions on applying the core administrative recipe.
 */
function leap_admin_help(string $route_name, RouteMatchInterface $route_match): string {
  if ($route_name === 'help.page.leap_admin') {
    $module_path = \Drupal::service('extension.list.module')->getPath('leap_admin');
    $command = "drush recipe $module_path/recipes/leap_admin";

    $output = '<h3>' . t('About') . '</h3>';
    $output .= '<p>' . t('The Splash Frog Administrative Enhancements module provides custom actions and core UI logic. When the accompanying recipe is installed, it provides improved Views for Content and Media management.') . '</p>';
    $output .= '<h3>' . t('Installation Instructions') . '</h3>';
    $output .= '<p>' . t('To install the enhanced Views and Pathauto patterns, you must run the following Drush command from your project root:') . '</p>';
    $output .= '<pre><code>' . $command . '</code></pre>';
    $output .= '<h3>' . t('Bulk Moderation Service') . '</h3>';
    $output .= '<p>' . t('Developers can use the <code>leap_admin.bulk_moderation</code> service to safely transition entities between moderation states across all translations.') . '</p>';
    $output .= '<h4>' . t('Example Usage:') . '</h4>';
    $output .= '<pre><code>';
    $output .= "/** @var \\Drupal\\leap_admin\\BulkModerationService \$moderation_service */\n";
    $output .= "\$moderation_service = \\Drupal::service('leap_admin.bulk_moderation');\n";
    $output .= "\$updated_entity = \$moderation_service->transitionNode(\$node, 'archived');\n";
    $output .= '</code></pre>';
    $output .= '<h3>' . t('Action Plugins') . '</h3>';
    $output .= '<p>' . t('This module provides strictly-typed PHP 8 action plugins for bulk archiving and publishing nodes. These can be utilized in Views bulk operations.') . '</p>';

    return $output;
  }

  return '';
}

/**
 * Implements hook_page_attachments().
 *
 * Attaches the environment indicator library to the page for authenticated
 * users with toolbar access. This provides a visual cue (via CSS) to help
 * administrators distinguish between local, dev, and production environments.
 */
function leap_admin_page_attachments(array &$attachments): void {
  $user = \Drupal::currentUser();

  // Check if the user is authenticated and has permission to access the toolbar.
  if ($user->isAuthenticated() && $user->hasPermission('access toolbar')) {
    $attachments['#attached']['library'][] = 'leap_admin/gin_toolbar_environment_indicator';
  }
}
